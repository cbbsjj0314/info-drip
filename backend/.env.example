# InfoDrip backend local environment

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

APP_ENV=local

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# SQLite database URL for local backend state.
INFODRIP_DATABASE_URL=sqlite:///./info_drip.db

# Directory where uploaded PDFs are stored.
INFODRIP_UPLOAD_DIR=uploads/documents

# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------

# Supported values: fake, openai-compatible.
# Use fake for local backend checks without external LLM calls.
INFODRIP_LLM_PROVIDER=fake

# Required only when INFODRIP_LLM_PROVIDER=openai-compatible.
# Keep the real value in local environment only; do not commit secrets.
INFODRIP_OPENAI_API_KEY=

# Required only when INFODRIP_LLM_PROVIDER=openai-compatible.
INFODRIP_OPENAI_MODEL=

# Optional. Custom OpenAI-compatible base URL.
# Leave blank for default OpenAI API.
INFODRIP_OPENAI_BASE_URL=

# Supported values: json_schema, json_object.
# Default json_schema keeps strict provider-side schema enforcement.
# Use json_object only for providers that require JSON object mode.
INFODRIP_OPENAI_RESPONSE_FORMAT=json_schema
